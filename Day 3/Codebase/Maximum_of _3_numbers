import java.util.Scanner;

public class MaximumOf3 {
    public static void main(String[] args) {
        Scanner sc=new Scanner(System.in);

        System.out.println("Enter the 3 numbers : ");
        int a=sc.nextInt();
        int b=sc.nextInt();
        int c=sc.nextInt();

        if(a>b&&a>c){
            System.out.println("Maximum of 3 is "+a);
        }
        else if(b>c){
            System.out.println("Maximum of 3 is "+b);
        }
        else{
            System.out.println("Maximum of 3 is "+c);
        }
    }
}
